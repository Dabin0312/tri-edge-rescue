# Optional runtime overrides for local demos and Jetson deployment.
#
# By default scripts set TRI_EDGE_HOME to the cloned repository root.
# Export this when running nodes manually from another directory.
TRI_EDGE_HOME=~/tri-edge-rescue

# Optional absolute DB path. If unset, the project uses:
# $TRI_EDGE_HOME/db/mission_events.db
# TRI_EDGE_DB_PATH=~/tri-edge-rescue/db/mission_events.db

# Use "0" to force the deterministic planner when the Qwen model is not
# downloaded yet or when memory is tight. Use "1" or "auto" for Qwen.
TRI_EDGE_ENABLE_QWEN=auto
